---
// src/components/PageLoader.astro
---

<div id="app-loader">
  <div class="loader-content">
    <div class="spinner"></div>
    <div class="loading-text">加载中喵~</div>
  </div>
</div>

<script>
  // 1. 强行搬运：把加载器移动到 body 最外层，无视任何父容器的 transform 干扰
  const loader = document.getElementById('app-loader');
  if (loader && loader.parentElement !== document.body) {
    document.body.appendChild(loader);
  }

  // 2. 移除逻辑
  function removeLoader() {
    const loaderEl = document.getElementById('app-loader');
    if (loaderEl && loaderEl.style.opacity !== '0') {
      loaderEl.style.opacity = '0';
      setTimeout(() => {
        if (loaderEl.parentNode) {
          loaderEl.parentNode.removeChild(loaderEl);
        }
      }, 600);
    }
  }

  window.addEventListener('load', removeLoader);
  document.addEventListener('astro:page-load', removeLoader);
  setTimeout(removeLoader, 3000);
</script>

<style is:global>
  #app-loader {
    position: fixed !important; 
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 2147483647; 
    background-color: var(--sl-color-bg);
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.6s ease-out;
  }

  .loader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    transform: translateY(-5%); 
  }

  .spinner {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 3px solid rgba(245, 179, 188, 0.1);
    border-top-color: #e17686; 
    border-left-color: #f5b3bc; 
    box-shadow: 0 0 20px rgba(225, 118, 134, 0.4); 
    animation: spin 1s cubic-bezier(0.68, -0.55, 0.27, 1.55) infinite;
  }

  .loading-text {
    font-family: monospace;
    font-size: 0.9rem;
    font-weight: bold;
    color: #e17686;
    letter-spacing: 3px;
    animation: pulse 1.5s infinite;
  }

  @keyframes spin {
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(180deg) scale(1.2); }
    100% { transform: rotate(360deg) scale(1); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.5; transform: scale(0.95); }
    50% { opacity: 1; transform: scale(1); }
  }
</style>