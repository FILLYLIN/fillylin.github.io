---
// src/components/PageLoader.astro
---

<!-- 加载器容器 -->
<div id="app-loader">
  <div class="loader-content">
    <div class="spinner"></div>
    <div class="loading-text">加载中喵...</div>
  </div>
</div>

<script>
  // 立即执行：把加载器搬运到 body 最外层
  // 这样它就能无视任何父容器的限制，真正全屏显示
  const loader = document.getElementById('app-loader');
  if (loader) {
    document.body.appendChild(loader);
  }

  // 监听页面加载完成
  window.addEventListener('load', () => {
    const loaderElement = document.getElementById('app-loader');
    if (loaderElement) {
      // 淡出
      loaderElement.style.opacity = '0';
      // 移除
      setTimeout(() => {
        loaderElement.style.display = 'none';
        loaderElement.remove(); // 彻底从 DOM 中删除，释放内存
      }, 600);
    }
  });

  // 保底策略 (防止网络卡顿导致一直转圈)
  setTimeout(() => {
    const loaderElement = document.getElementById('app-loader');
    if (loaderElement && loaderElement.style.opacity !== '0') {
      loaderElement.style.opacity = '0';
      setTimeout(() => { loaderElement.remove(); }, 600);
    }
  }, 3000); // 3秒后强制关闭，避免等待太久
</script>

<style is:global>
  /* 必须加上 is:global，否则样式可能会被 Astro 限制在组件内 */
  
  #app-loader {
    position: fixed !important; /* 强制固定 */
    top: 0;
    left: 0;
    width: 100vw; /* 视口宽度 */
    height: 100vh; /* 视口高度 */
    z-index: 2147483647; /* CSS 允许的最大 z-index，保证盖住所有东西 */
    
    /* 背景色：使用当前主题背景，并不透明 */
    background-color: var(--sl-color-bg);
    
    /* 居中布局 */
    display: flex;
    justify-content: center;
    align-items: center;
    
    /* 过渡效果 */
    transition: opacity 0.6s ease-out;
  }

  .loader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    /* 稍微往上提一点，视觉上更平衡 */
    transform: translateY(-5%); 
  }

  /* 旋转的粉色科技圈 */
  .spinner {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    
    border: 3px solid rgba(245, 179, 188, 0.1);
    border-top-color: #e17686; /* 深粉色 */
    border-left-color: #f5b3bc; /* 浅粉色 */
    
    box-shadow: 0 0 20px rgba(225, 118, 134, 0.4); /* 发光更强一点 */
    
    animation: spin 1s cubic-bezier(0.68, -0.55, 0.27, 1.55) infinite;
  }

  .loading-text {
    font-family: monospace;
    font-size: 0.9rem;
    font-weight: bold;
    color: #e17686;
    letter-spacing: 3px;
    animation: pulse 1.5s infinite;
  }

  @keyframes spin {
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(180deg) scale(1.2); }
    100% { transform: rotate(360deg) scale(1); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.5; transform: scale(0.95); }
    50% { opacity: 1; transform: scale(1); }
  }
</style>