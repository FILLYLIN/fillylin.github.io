---
// src/components/MapIframe.astro
---

<div class="map-glass-window">
  <!-- 你的地图链接 -->
  <iframe src="https://map-bangdream.lzalien.org/" title="服务器卫星地图" allowfullscreen></iframe>
</div>

<style is:global>
  /* 1. 强行解除 Starlight 默认的内容宽度限制 */
  .sl-container {
    max-width: 100% !important;
    margin: 0 !important;
    padding: 0 2rem !important; 
  }

  /* 2. 隐藏页面底部的版权和页脚信息 */
  footer {
    display: none !important;
  }

  /* 3. 巨型磨砂玻璃地图视窗 */
  .map-glass-window {
    width: 100%;
    height: calc(100vh - 8rem); 
    margin-top: -1rem; 
    
    background-color: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    
    border: 1px solid rgba(245, 179, 188, 0.8);
    border-radius: 20px;
    box-shadow: 0 8px 32px rgba(225, 118, 134, 0.3);
    
    overflow: hidden;
    position: relative;
    z-index: 10;
  }

  /* 4. iframe 本体 */
  .map-glass-window iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
    background-color: rgba(0, 0, 0, 0.1);
  }

  /* 暗黑模式适配 */
  [data-theme='dark'] .map-glass-window {
    background-color: rgba(20, 20, 20, 0.6);
    border: 1px solid rgba(245, 179, 188, 0.3);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  }

  /* 手机端适配 */
  @media (max-width: 50rem) {
    .sl-container { padding: 0 !important; }
    .map-glass-window {
      border-radius: 0;
      border-left: none;
      border-right: none;
      height: calc(100vh - 4rem);
    }
  }
</style>